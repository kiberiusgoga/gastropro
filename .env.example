DATABASE_URL=postgres://postgres:password@localhost:5432/gastropro
NODE_ENV=development
PORT=4000
JWT_SECRET=change-me-use-a-long-random-secret
JWT_REFRESH_SECRET=change-me-use-a-different-long-random-secret

# Comma-separated list of allowed CORS origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,https://app.gastropro.mk

# Frontend URL used in password reset emails
FRONTEND_URL=http://localhost:5173

# SMTP configuration (optional — omit to log emails to console instead)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=yourpassword
# SMTP_FROM=noreply@gastropro.mk
