DATABASE_URL=postgres://postgres:password@localhost:5432/gastropro
# NODE_ENV — do NOT put this in .env; set it in the deploy environment instead.
# (Having NODE_ENV=development in .env causes Vite to build with DEV mode enabled,
#  which includes dev-only UI like the Demo Login button in production bundles.)
PORT=4000
JWT_SECRET=change-me-use-a-long-random-secret
JWT_REFRESH_SECRET=change-me-use-a-different-long-random-secret

# Comma-separated list of allowed CORS origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,https://app.gastropro.mk

# Frontend URL used in password reset emails
FRONTEND_URL=http://localhost:5173

# SMTP configuration (optional — omit to log emails to console instead)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=yourpassword
# SMTP_FROM=noreply@gastropro.mk

# Image uploads — Cloudinary (optional — falls back to local /uploads/ if unset)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# AI features — Gemini (optional — AI endpoints degrade gracefully if unset)
# GEMINI_API_KEY=your-gemini-api-key
