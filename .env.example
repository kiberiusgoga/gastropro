# Google Maps API Key
GOOGLE_MAPS_API_KEY=

# Gemini API Key (handled by platform, but good to document)
GEMINI_API_KEY=

# Database
DATABASE_URL=postgres://user:password@localhost:5432/roadtrip

# Authentication
JWT_SECRET=your_jwt_secret_here
REFRESH_SECRET=your_refresh_token_secret_here

# App
PORT=3000
NODE_ENV=development
